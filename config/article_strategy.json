    "Health insurance for immigrants USA",
    "TFSA guide for newcomers Canada",
    "RRSP explained for immigrants Canada",
    "Tax filing for newcomers Canada CRA",
    "How to get SSN as international student",
    "Banking without credit history USA immigrants",
    "Car insurance for newcomers USA",
    "Renters insurance for immigrants USA"
  ],
  "production_limits": {
    "max_articles_per_day": 6,
    "max_articles_per_batch": 3,
    "batch_1_time": "06:00 UTC",
    "batch_2_time": "13:00 UTC",
    "pillar_max_per_day": 2,
    "standard_max_per_day": 4,
    "note": "max_articles_per_day is a CEILING, never a quota. Never produce filler to reach it; only publish topics that pass every quality gate."
