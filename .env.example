# ================================================================
# NEXUS-14 MoneyAbroadGuide Autonomous Newsroom V1
# Environment Configuration Template
# Copy this file to .env and fill in your actual values
# ================================================================

# ----------------------------------------------------------------
# ENVIRONMENT
# ----------------------------------------------------------------
ENVIRONMENT=production
RUN_MODE=scheduled
LOG_LEVEL=INFO
DEBUG=false

# ----------------------------------------------------------------
# LLM APIS
# ----------------------------------------------------------------
# Primary LLM (Article writing, EEAT, Chief Editor)
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_MAX_TOKENS=4096

# Anthropic Claude LLM
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# ----------------------------------------------------------------
# NEXUS-14 MODEL PANACHAGE (per-agent — see docs/NEXUS14_MODEL_PANACHAGE.md)
# ----------------------------------------------------------------
# Default primary/fallback for structured tasks (research, keyword, outline).
# Never try the same model twice — LLMService dedupes primary vs fallback.
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MODEL_FALLBACK=claude-opus-4-8

# Article writer (agent_04) — the single agent whose output IS the product.
# Fable 5 is Anthropic's most capable model; ~2x cost vs Opus but justified
# for YMYL financial content that must rank on Google. Requires org data
# retention >= 30 days (ZDR orgs will 400 — switch to claude-opus-4-8 then).
ARTICLE_WRITER_MODEL=claude-fable-5

# EEAT validator (agent_06) — same rationale as writer (fine judgment).
EEAT_MODEL=claude-fable-5

# Fact checker (agent_05) — structured verification, Opus is sufficient.
FACT_CHECK_MODEL=claude-opus-4-8

# QA (agent_12) + Chief Editor (agent_13) — gate decisions.
QA_MODEL=claude-opus-4-7
EDITOR_MODEL=claude-opus-4-7

# Reporting (agent_14) — HTML rendering; cheapest tier is fine.
REPORTING_MODEL=claude-haiku-4-5

# ⚠️ BREAKING CHANGES on the new model family (Fable 5, Opus 4.7/4.8, Sonnet 5):
#   - `temperature`, `top_p`, `top_k` are REJECTED (400) — steer via prompts.
#   - `thinking: {type: "enabled", budget_tokens: N}` is REJECTED (400) —
#     use `thinking: {type: "adaptive"}` instead.
#   - Fable 5: last-assistant-turn prefills are REJECTED (400) — use
#     `output_config.format` for structured outputs.
#   - Fable 5: `thinking: {type: "disabled"}` is REJECTED (400) — omit the
#     field entirely.
#   - Fable 5: requires 30-day org data retention (ZDR orgs get 400 on
#     every request). Fallback `claude-opus-4-8` is ZDR-compatible.

# Image generation
GEMINI_API_KEY=your-gemini-key-here
DALLE_API_KEY=your-dalle-key-here
NANO_BANANA_KEY=your-nano-banana-key-here

# ----------------------------------------------------------------
# SEARCH APIs
# ----------------------------------------------------------------
SERPAPI_KEY=your-serpapi-key-here
SEMRUSH_API_KEY=your-semrush-key-here
AHREFS_API_KEY=your-ahrefs-key-here
MOZ_ACCESS_ID=your-moz-access-id
MOZ_SECRET_KEY=your-moz-secret-key

# ----------------------------------------------------------------
# WORDPRESS
# ----------------------------------------------------------------
WORDPRESS_URL=https://moneyabroadguide.com
WORDPRESS_USERNAME=your-wordpress-username
WORDPRESS_APP_PASSWORD=your-wordpress-app-password

# WordPress author configuration
WORDPRESS_AUTHOR_ID=1
WORDPRESS_AUTHOR_NAME=MoneyAbroadGuide Editorial Team
WORDPRESS_DEFAULT_CATEGORY=expat-banking

# ----------------------------------------------------------------
# EMAIL (SendGrid)
# ----------------------------------------------------------------
SENDGRID_API_KEY=SG.your-sendgrid-key-here
EMAIL_FROM=noreply@moneyabroadguide.com
EMAIL_FROM_NAME=NEXUS-14 Newsroom
EMAIL_RECIPIENT=talalnewjersey@gmail.com
EMAIL_RECIPIENT_CC=
EMAIL_SUBJECT_PREFIX=[NEXUS-14]

# ----------------------------------------------------------------
# STORAGE (AWS S3)
# ----------------------------------------------------------------
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET=mag-newsroom-assets
S3_PREFIX=nexus14/

# ----------------------------------------------------------------
# DATABASE (Redis for caching)
# ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=your-redis-password
REDIS_TTL=86400

# ----------------------------------------------------------------
# PRODUCTION SETTINGS
# ----------------------------------------------------------------
# Number of articles per production batch
ARTICLES_PER_BATCH=5

# Content quality thresholds
MIN_WORD_COUNT=5000
MAX_WORD_COUNT=10000
MIN_SEO_SCORE=95
MIN_EEAT_SCORE=95
MIN_IMAGES=4

# Scheduling (24h format, UTC)
MORNING_BATCH_TIME=06:00
AUDIT1_TIME=09:30
MORNING_REPORT_TIME=09:45
EVENING_BATCH_TIME=10:00
AUDIT2_TIME=16:30
EVENING_READY_TIME=18:00
EXECUTIVE_REPORT_TIME=18:30

# ----------------------------------------------------------------
# SEO SETTINGS
# ----------------------------------------------------------------
TARGET_MARKETS=USA,Canada
MIN_SEARCH_VOLUME=500
MAX_KEYWORD_DIFFICULTY=65
TOPICS_PER_BATCH=10

# ----------------------------------------------------------------
# AFFILIATE PROGRAMS
# ----------------------------------------------------------------
WISE_AFFILIATE_ID=your-wise-affiliate-id
REVOLUT_AFFILIATE_ID=your-revolut-affiliate-id
OFX_AFFILIATE_ID=your-ofx-affiliate-id
REMITLY_AFFILIATE_ID=your-remitly-affiliate-id

# ----------------------------------------------------------------
# MONITORING
# ----------------------------------------------------------------
SENTRY_DSN=your-sentry-dsn-here
PROMETHEUS_PORT=9090
HEALTH_CHECK_INTERVAL=300

# ================================================================
# IMPORTANT: Never commit the actual .env file to version control!
# Add .env to your .gitignore
# ================================================================
